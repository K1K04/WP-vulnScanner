# ═══════════════════════════════════════════════════════════════════════════════
# WP VulnScanner Pro — Configuración de entorno
# ───────────────────────────────────────────────────────────────────────────────
# Copia este archivo:   cp .env.example .env
# Edita .env con tus valores reales.
# NUNCA subas .env a Git — ya está en .gitignore.
# ═══════════════════════════════════════════════════════════════════════════════


# ── SEGURIDAD ─────────────────────────────────────────────────────────────────

# [OBLIGATORIO en producción] Clave secreta de Flask para firmar sesiones/cookies.
# Genera una segura con:
#   python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=cambia-esto-por-un-valor-aleatorio-seguro-minimo-32-chars

# [Opcional] Clave de API para proteger todos los endpoints /api/*
# Si la defines, cada petición debe incluir la cabecera:
#   X-API-Key: <valor>
# Deja vacío para modo desarrollo (sin autenticación de API).
API_KEY=

# [Opcional] Protección de interfaz web (UI) con HTTP Basic Auth.
# Si defines ambos valores, páginas y endpoints UI (/, /scan, /history, /compare, /settings, /static/* ...)
# requerirán usuario/contraseña en el navegador.
# Nota: /api/* mantiene su esquema actual con X-API-Key.
UI_BASIC_AUTH_USER=
UI_BASIC_AUTH_PASS=


# ── RED ───────────────────────────────────────────────────────────────────────

# Permitir escanear IPs privadas (192.168.x.x, 10.x.x.x, 127.x.x.x, ::1, fd00::)
#   SCAN_SCOPE=public → solo objetivos públicos (bloquea SSRF IPv4 e IPv6)
#   SCAN_SCOPE=all    → permite objetivos públicos, locales e internos
# Compatibilidad legacy: ALLOW_PRIVATE_IPS=true equivale a SCAN_SCOPE=all
SCAN_SCOPE=public
ALLOW_PRIVATE_IPS=false

# Verificar el certificado SSL del sitio escaneado.
#   true  → producción (recomendado)
#   false → solo en laboratorios con certificados autofirmados
VERIFY_SSL=true


# ── ESCÁNER ───────────────────────────────────────────────────────────────────

# Timeout de cada petición HTTP individual (segundos). Default: 12
SCANNER_TIMEOUT=12

# Máximo de hilos paralelos dentro de un escaneo. Default: 12
# Reducir en servidores con poca RAM o CPU.
SCANNER_MAX_WORKERS=12

# Timeout global de un escaneo completo (segundos). Default: 300 (5 min)
# Si el sitio es muy lento sube a 600. Nunca poner por debajo de 60.
SCAN_TIMEOUT_SECONDS=300

# Timeout duro del motor completo (segundos). Si un módulo queda colgado,
# se corta el job y se devuelve resultado parcial/timeout.
# Recomendado: igual o ligeramente mayor que SCAN_TIMEOUT_SECONDS.
SCAN_HARD_TIMEOUT_SECONDS=300

# Máximo de escaneos ejecutándose a la vez. Default: 5
# Cada escaneo consume ~1 hilo del sistema + conexiones de red.
MAX_CONCURRENT_SCANS=5

# Rate limit de escaneos desde la UI por IP y minuto. Default: 5
RATE_LIMIT_ENABLED=false
SCAN_RATE_LIMIT=0

# Rate limit de llamadas a /api/scan por IP y minuto. Default: 3
API_RATE_LIMIT=0

# Timeout del módulo de Threat Intelligence (EPSS + CISA KEV) en segundos. Default: 15
# Aumentar si la red es lenta o si CISA/EPSS tienen latencia alta.
THREAT_INTEL_TIMEOUT=15


# ── SERVIDOR ──────────────────────────────────────────────────────────────────

# Imagen Docker a usar en docker-compose.yml
# Si mantienes estos defaults, se usará Docker Hub: kiko4/wpvulnscan:3.0
# En despliegues internos puedes apuntar a otro registro:
#   IMAGE_REPO=registry.empresa.local/security/wpvulnscan
#   IMAGE_TAG=3.0
IMAGE_REPO=kiko4/wpvulnscan
IMAGE_TAG=3.0

# Interfaz de red en la que escucha Flask. Default: 127.0.0.1
#   127.0.0.1  → solo acceso local (recomendado detrás de nginx/caddy)
#   0.0.0.0    → todas las interfaces (solo si no hay proxy inverso)
HOST=127.0.0.1

# Puerto TCP. Default: 5000
PORT=5000

# Modo debug de Flask. NUNCA true en producción (expone traceback completo).
DEBUG=false

# Ruta al fichero de log con rotación automática (10 MB × 5 copias).
# Deja vacío para loguear solo a stdout.
# Ejemplo: LOG_FILE=/var/log/wpvulnscan/app.log
LOG_FILE=


# ── APIS EXTERNAS (todas opcionales) ─────────────────────────────────────────

# WPScan API — https://wpscan.com/api
#   Sin token: usa la BD local (vulns.db) — suficiente para la mayoría de usos.
#   Con token: enriquece los resultados con datos en tiempo real de WPScan.
#   Plan free: 25 peticiones/día.
WPSCAN_API_TOKEN=

# GitHub Personal Access Token — https://github.com/settings/tokens
#   Mejora el rate limit de GitHub Advisory DB en update_vulns.py
#   (sin token: 60 req/h anónimas; con token: 5000 req/h).
#   Permisos necesarios: ninguno (solo lectura pública).
GITHUB_TOKEN=

# VirusTotal API — https://www.virustotal.com/gui/my-apikey
#   Usado para reputación de IPs/dominios del sitio escaneado.
VT_API_KEY=

# AbuseIPDB API — https://www.abuseipdb.com/account/api
#   Comprueba si la IP del servidor está en listas de abuso.
ABUSEIPDB_API_KEY=

# Google Safe Browsing API — https://console.cloud.google.com/
#   Verifica si la URL está marcada como phishing o malware por Google.
GSB_API_KEY=


# ── SMTP — Notificaciones de escaneos programados ─────────────────────────────
# Si no configuras SMTP, las notificaciones se omiten silenciosamente.

# Servidor SMTP (ej: smtp.gmail.com, smtp.office365.com, mail.tu-empresa.com)
SMTP_HOST=smtp.gmail.com

# Puerto SMTP. Valores habituales:
#   587 → STARTTLS (recomendado)
#   465 → SSL/TLS
#   25  → sin cifrado (no recomendado)
SMTP_PORT=587

# Credenciales SMTP
SMTP_USER=tu@gmail.com
SMTP_PASS=contraseña-de-aplicación-aquí

# Dirección remitente (From:). Por defecto usa SMTP_USER si se deja vacío.
SMTP_FROM=


# ── PWA — Web Push Notifications ─────────────────────────────────────────────
# Necesario para recibir notificaciones push en el navegador al terminar escaneos.
# Si no configuras VAPID, las notificaciones push se desactivan automáticamente.
#
# Genera las claves VAPID:
#   pip install pywebpush
#   python3 -c "
#     from py_vapid import Vapid
#     v = Vapid()
#     v.generate_keys()
#     print('VAPID_PRIVATE_KEY=' + v.private_key)
#     print('VAPID_PUBLIC_KEY='  + v.public_key)
#   "
VAPID_PRIVATE_KEY=
VAPID_PUBLIC_KEY=

# Email de contacto del dueño VAPID (requerido por la especificación Web Push).
VAPID_EMAIL=mailto:admin@tu-dominio.com

# ── IA — Plan de remediación y chat asistido ──────────────────────────────────
# Proveedor IA por defecto:
#   auto   -> usa Gemini, fallback a Claude (si hay clave) y luego a Ollama
#   gemini -> fuerza Gemini (requiere GEMINI_API_KEY)
#   claude -> fuerza Claude (requiere ANTHROPIC_API_KEY)
#   ollama -> fuerza Ollama local (modo gratis, sin API key)
AI_PROVIDER=auto

# Gemini (opcional, pero recomendado para mejor calidad)
# Obtén tu clave en: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Claude (Anthropic) — buena calidad para análisis/respuesta
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-haiku-4-5

# Ollama local (gratis) — alternativa cuando Gemini no tiene cuota
# Instalar: https://ollama.com/download
# Ejecutar: ollama serve
# Modelo recomendado:  ollama pull qwen2.5:3b
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen2.5:3b

# Lista de modelos alternativos para fallback automático (orden de preferencia)
# El backend elegirá el primero que encuentre instalado localmente cuando
# OLLAMA_MODEL no exista. Separados por coma.
OLLAMA_MODEL_FALLBACKS=qwen2.5:3b,qwen2.5:7b,llama3.2:3b,mistral:7b-instruct,phi3:mini

# Timeouts y límites de generación IA (segundos/tokens)
# Útil cuando usas modelos locales grandes (ej. 14b) y el plan tarda más en responder.
GEMINI_TIMEOUT_SECONDS=60
GEMINI_STREAM_TIMEOUT_SECONDS=90
CLAUDE_TIMEOUT_SECONDS=75
CLAUDE_STREAM_TIMEOUT_SECONDS=120
OLLAMA_TIMEOUT_SECONDS=180
OLLAMA_STREAM_TIMEOUT_SECONDS=180
OLLAMA_PLAN_TIMEOUT_SECONDS=300
OLLAMA_TAGS_TIMEOUT_SECONDS=5
AI_PLAN_MAX_TOKENS=2048
AI_PLAN_RETRY_MAX_TOKENS=1536
OLLAMA_PLAN_RETRY_TIMEOUT_SECONDS=360

SCANNER_REQUEST_DELAY=0.5    # delay entre peticiones en segundos (0=desactivado, recomendado: 0.3-1.0)

# Fuerza ejecución del análisis pasivo/deep genérico aunque no se confirme WordPress.
# Recomendado true para dominios mixtos o no-WP donde igualmente quieres señales de exposición.
SCANNER_FORCE_GENERIC_PASSIVE=true

# ── CACHE DE RESULTADOS ────────────────────────────────────────────────────────
# Tiempo en segundos que se guarda el resultado de un escaneo en memoria.
# Si el mismo dominio se escanea dentro de este periodo, se devuelve
# el resultado cacheado al instante sin volver a contactar el sitio.
#   3600 → 1 hora (recomendado)
#   0    → desactiva el cache completamente
SCAN_CACHE_TTL=0
